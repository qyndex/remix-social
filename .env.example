# Remix Social — environment variables
# Copy to .env and fill in values

# Session secret (required for cookie-based sessions — replace with real auth)
SESSION_SECRET=change-me-to-a-long-random-string

# App URL (used for absolute redirects / canonical links)
APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Database (replace in-memory store with a real DB connection string)
# DATABASE_URL=postgresql://user:password@localhost:5432/remix_social
